generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Chat Agent ───────────────────────────────────────────

model ChatConversation {
  id           String        @id @default(cuid())
  visitorName  String?
  visitorEmail String?
  sessionId    String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
  leads        Lead[]

  @@index([visitorEmail])
  @@index([createdAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

// ─── Analytics ────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

// ─── Blog ─────────────────────────────────────────────────

model BlogPost {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  content         String       @db.Text
  excerpt         String?      @db.Text
  metaDescription String?
  coverImageUrl   String?
  status          String       @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  viewCount       Int          @default(0)
  socialPosts     SocialPost[]

  @@index([status, publishedAt])
  @@index([slug])
}

// ─── Social Media ─────────────────────────────────────────

model SocialPost {
  id              String       @id @default(cuid())
  blogPostId      String?
  blogPost        BlogPost?    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  topic           String?
  caption         String       @db.Text
  hashtags        String       @db.Text
  facebookContent String?      @db.Text
  imageUrl        String?
  blogUrl         String?
  status          String       @default("draft")
  sentAt          DateTime?
  createdAt       DateTime     @default(now())
  publishLogs     PublishLog[]

  @@index([blogPostId])
}

model SocialConnection {
  id                  String    @id @default(cuid())
  platform            String    @unique
  userAccessToken     String    @db.Text
  userAccessTokenIv   String
  userAccessTokenTag  String
  pageAccessToken     String?   @db.Text
  pageAccessTokenIv   String?
  pageAccessTokenTag  String?
  tokenExpiresAt      DateTime?
  status              String    @default("active")
  pageId              String?
  pageName            String?
  igBusinessAccountId String?
  igUsername           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
}

model PublishLog {
  id             String      @id @default(cuid())
  socialPostId   String?
  socialPost     SocialPost? @relation(fields: [socialPostId], references: [id], onDelete: SetNull)
  platform       String
  contentSnippet String?     @db.VarChar(100)
  status         String
  platformPostId String?
  platformUrl    String?
  error          String?     @db.Text
  publishedAt    DateTime    @default(now())

  @@index([socialPostId])
  @@index([platform])
  @@index([publishedAt])
}

model TokenRefreshLog {
  id          String   @id @default(cuid())
  platform    String
  attemptedAt DateTime @default(now())
  success     Boolean
  error       String?  @db.Text

  @@index([platform])
  @@index([attemptedAt])
}

// ─── Leads ──────────────────────────────────────────────

model Lead {
  id             String            @id @default(cuid())
  name           String
  email          String?
  phone          String?
  status         String            @default("new") // new, contacted, booked, closed
  notes          String?           @db.Text
  conversationId String?
  conversation   ChatConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

// ─── Admin Session ────────────────────────────────────────

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}
